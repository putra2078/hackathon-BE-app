// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Expense {
  id          String   @id @default(uuid())
  name        String
  amount      Float
  category    String?
  description String?
  createdAt   DateTime @default(now())

  @@map("expenses")
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  products    Product[]

  @@map("categories")
}

model Product {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  image       String?
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  buyPrice    Float
  sellPrice   Float
  stock       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  boughtDetails BoughtProductDetail[]
  stockIncrements StockIncrement[]

  @@map("products")
}

model StockIncrement {
  id        String   @id @default(uuid())
  productId String
  userId    String
  quantity  Int
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@map("stock_increments")
}

model User {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  password    String
  companyId   String?  @map("company_id")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions    Transaction[]
  stockIncrements StockIncrement[]
  conversations   Conversation[]

  @@map("users")
}

model Transaction {
  id           String   @id @default(uuid())
  userId       String
  companyId    String?  @map("company_id")
  customerName String?
  totalPrice   Float
  status       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user               User                @relation(fields: [userId], references: [id])
  detailTransactions DetailTransaction[]

  @@map("transactions")
}

model DetailTransaction {
  id                String   @id @default(uuid())
  transactionId     String
  totalCapital      Float
  totalProfit       Float
  discount          Float    @default(0)
  paymentAmount     Float
  changeAmount      Float
  paymentMethod     String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  transaction   Transaction           @relation(fields: [transactionId], references: [id])
  boughtProducts BoughtProductDetail[]

  @@map("detail_transactions")
}

model BoughtProductDetail {
  id                  String   @id @default(uuid())
  detailTransactionId String
  productId           String
  name                String // Snapshot name
  code                String // Snapshot code
  buyPrice            Float // Snapshot buy price
  sellPrice           Float // Snapshot sell price
  quantity            Int
  subtotal            Float
  createdAt           DateTime @default(now())

  detailTransaction DetailTransaction @relation(fields: [detailTransactionId], references: [id])
  product           Product           @relation(fields: [productId], references: [id])

  @@map("bought_product_details")
}

model Conversation {
  id          String   @id @default(uuid())
  userId      String
  title       String   @default("New Conversation")
  lastMessage String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]
  summaries Summary[]

  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  role           String
  content        String
  token          Int?     @default(0)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  attachments  Attachment[]

  @@map("messages")
}

model Summary {
  id             String   @id @default(uuid())
  conversationId String
  summary        String
  lastMessageId  String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("summaries")
}

model Attachment {
  id        String   @id @default(uuid())
  messageId String
  filename  String
  mimeType  String
  url       String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("attachments")
}
